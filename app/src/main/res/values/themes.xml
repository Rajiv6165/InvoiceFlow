<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.InvoiceFlow" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="android:colorPrimary">@color/invoiceflow_primary</item>
        <item name="android:colorPrimaryVariant">@color/invoiceflow_primary_variant</item>
        <item name="android:colorOnPrimary">@color/invoiceflow_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="android:colorSecondary">@color/invoiceflow_secondary</item>
        <item name="android:colorSecondaryVariant">@color/invoiceflow_secondary</item>
        <item name="android:colorOnSecondary">@color/invoiceflow_on_secondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/invoiceflow_primary_variant</item>
        <!-- Background color. -->
        <item name="android:colorBackground">@color/invoiceflow_background</item>
        <!-- Surface color. -->
        <item name="android:colorForeground">@color/invoiceflow_surface</item>
    </style>
</resources>
