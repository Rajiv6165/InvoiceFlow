<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.InvoiceFlow" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="android:colorPrimary">@color/invoiceflow_primary</item>
        <item name="android:colorPrimaryDark">@color/invoiceflow_primary_variant</item>
        <item name="android:colorAccent">@color/invoiceflow_secondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/invoiceflow_primary_variant</item>
        <!-- Background color. -->
        <item name="android:windowBackground">@color/invoiceflow_background</item>
        <item name="android:colorBackground">@color/invoiceflow_background</item>
    </style>

    <!-- Splash Screen Starting Theme -->
    <style name="Theme.InvoiceFlow.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A237E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.InvoiceFlow</item>
    </style>
</resources>
