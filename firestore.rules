rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user belongs to store
    function isStoreMember(storeId) {
      return request.auth != null && 
             get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.storeId == storeId;
    }
    
    // Helper function to get user's storeId
    function getUserStoreId() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.storeId;
    }
    
    // Stores collection - read-only for members, no client-side writes
    match /Stores/{storeId} {
      allow read: if isStoreMember(storeId);
      allow write: if false; // Only admins via cloud functions or server SDK
    }
    
    // Users collection - users can read their own profile and update limited fields
    match /Users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && 
                      request.resource.data.storeId == getUserStoreId();
      allow update: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.data.storeId == resource.data.storeId;
      allow delete: if false;
    }
    
    // Products collection - store-based isolation
    match /Products/{productId} {
      allow read: if request.auth != null &&
                     resource.data.storeId == getUserStoreId();
      allow create: if request.auth != null &&
                       request.resource.data.storeId == getUserStoreId();
      allow update, delete: if false; // Owner-only via additional role checks
    }
    
    // Invoices collection - cashier can create, owner can read all store invoices
    match /Invoices/{invoiceId} {
      allow read: if request.auth != null &&
                     resource.data.storeId == getUserStoreId();
      allow create: if request.auth != null &&
                       request.resource.data.storeId == getUserStoreId();
      allow update, delete: if false;
    }
    
    // Settings collection per store
    match /StoreSettings/{storeId} {
      allow read: if isStoreMember(storeId);
      allow write: if false; // Owner-only via additional role checks
    }
  }
}
