rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data;
    }
    
    function isOwner() {
      return getUserData().role == 'OWNER';
    }
    
    function belongsToStore(storeId) {
      return getUserData().storeId == storeId;
    }
    
    function isActiveUser() {
      return getUserData().isActive == true;
    }
    
    function hasValidSubscription(storeId) {
      let store = get(/databases/$(database)/documents/Stores/$(storeId)).data;
      return store.subscriptionStatus in ['trial', 'active'];
    }
    
    // Stores - owners can read their own store
    match /Stores/{storeId} {
      allow read: if isAuthenticated() && belongsToStore(storeId) 
                     && isActiveUser();
      allow write: if isAuthenticated() && isOwner() 
                      && belongsToStore(storeId);
    }
    
    // Users - each user reads own doc, owners read store users
    match /Users/{userId} {
      allow read: if isAuthenticated() && 
                     (request.auth.uid == userId || 
                      (isOwner() && belongsToStore(resource.data.storeId)));
      allow create: if isAuthenticated() && isOwner();
      allow update: if isAuthenticated() && 
                       (request.auth.uid == userId || isOwner());
      allow delete: if false;
    }
    
    // Products - store members can read, owners can write
    match /Products/{productId} {
      allow read: if isAuthenticated() 
                     && belongsToStore(resource.data.storeId)
                     && isActiveUser()
                     && hasValidSubscription(resource.data.storeId);
      allow create: if isAuthenticated() && isOwner()
                       && request.resource.data.storeId == getUserData().storeId;
      allow update: if isAuthenticated() && isOwner()
                       && resource.data.storeId == getUserData().storeId;
      allow delete: if isAuthenticated() && isOwner()
                       && resource.data.storeId == getUserData().storeId;
    }
    
    // Invoices - any store member can create, owner can read all
    match /Invoices/{invoiceId} {
      allow read: if isAuthenticated() 
                     && belongsToStore(resource.data.storeId)
                     && isActiveUser();
      allow create: if isAuthenticated()
                       && belongsToStore(request.resource.data.storeId)
                       && isActiveUser()
                       && hasValidSubscription(request.resource.data.storeId);
      allow update, delete: if false;
    }
    
    // Activity Logs - create by any active user, read by owner only
    match /ActivityLogs/{storeId}/logs/{logId} {
      allow read: if isAuthenticated() && isOwner() 
                     && belongsToStore(storeId);
      allow create: if isAuthenticated() && belongsToStore(storeId)
                       && isActiveUser();
      allow update, delete: if false;
    }
    
    // SuperAdmin - completely locked from client app
    match /SuperAdmin/{document=**} {
      allow read, write: if false;
    }
  }
}
